# ---- Production environment variables ----
# Copy to .env.local (gitignored) and fill in real values for local dev.
# In Vercel, set these in Project → Settings → Environment Variables.

# Resend (https://resend.com) — used by the /contact form to send email.
# If unset, contact form will log to server console and still return success.
RESEND_API_KEY=

# Optional override. Defaults to no-reply@joekhalaf.com.
# Must be on a domain you've verified in Resend.
# CONTACT_FROM_EMAIL=no-reply@joekhalaf.com
